# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
crash.log
*.tfvars
!terraform.tfvars.example
**/secrets.tfvars

# AWS Credentials - NEVER commit
.aws/
credentials
config
**/*.pem
**/*.key

# Kubernetes
**/.kube/
kubeconfig
*.kubeconfig

# Docker
.docker/
image.tar

# Node.js
**/node_modules/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
/**/package-lock.json

# Environment files (single entry, no duplicates)
**/.env
**/.env.local
**/.env.*.local

# Python
**/__pycache__/
**/*.py[cod]
**/.Python
**/.venv
**/.mypy_cache/
**/.pytest_cache/
**/.ruff_cache/

# Build outputs
**/build/
**/dist/
**/*.egg-info/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files (single entry each)
**/.DS_Store
**/.Spotlight-V100
**/.Trashes
ehthumbs.db
Thumbs.db

# Logs
**/*.log
**/logs/

# Temporary files
**/.tmp/
**/temp/

# Local development
docker-compose.override.yml
k8s/local-*.yaml

# Sensitive files
**/secrets.yaml
